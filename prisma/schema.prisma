// Timma — database schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentication & Users ────────────────────────────────────────────

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caregiver Caregiver?
  profiles  Profile[]
  kanbanBoards KanbanBoard[]
}

model Caregiver {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  householdId String    @unique
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  avatarUrl String?
  pin       String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  // Preferences
  viewMode     ViewMode     @default(BLOCKS)
  themeId      String?
  theme        Theme?       @relation(fields: [themeId], references: [id])
  sensoryMode  SensoryMode  @default(LOW_STIMULATION)
  rewardType   RewardType   @default(POINTS)

  calendarToken String?  @unique

  // Relations
  activities   Activity[]
  rewards      Reward[]
  redemptions  Redemption[]
  earnedPoints EarnedPoint[]
  badges       Badge[]
  earnedBadges EarnedBadge[]
  uploadedSignVideos SignVideo[] @relation("UploadedSignVideos")
  favoriteSymbols  FavoriteSymbol[]
}

enum Role {
  ADMIN
  USER
}

enum ViewMode {
  TIMELINE
  BLOCKS
  CARDS
}

enum SensoryMode {
  LOW_STIMULATION
  HIGH_ENGAGEMENT
}

enum RewardType {
  POINTS
  TOKENS
  STARS
  BADGES
}

// ─── Unified Task / Activity ───────────────────────────────────────────

model Activity {
  id          String      @id @default(cuid())
  title       String
  description String?
  color       String?
  startTime   DateTime?
  endTime     DateTime?
  allDay      Boolean     @default(false)
  status      TaskStatus  @default(BACKLOG)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  recurrence  Recurrence?

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  symbolId String?
  symbol   Symbol? @relation(fields: [symbolId], references: [id])
  imageUrl String?

  signVideoId String?
  signVideo   SignVideo? @relation(fields: [signVideoId], references: [id])

  pointValue  Int     @default(0)
  earnedPoints EarnedPoint[]

  kanbanColumnId String?
  kanbanColumn   KanbanColumn? @relation(fields: [kanbanColumnId], references: [id], onDelete: SetNull)
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

enum Recurrence {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
}

// ─── Visual Support (PECS & Teckenstöd) ───────────────────────────────

model Symbol {
  id       String       @id @default(cuid())
  name     String
  imageUrl String
  category String
  source   SymbolSource @default(MULBERRY)

  activities      Activity[]
  favoriteSymbols FavoriteSymbol[]
}

enum SymbolSource {
  MULBERRY
  CUSTOM
}

model FavoriteSymbol {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  symbolId String
  symbol   Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@unique([profileId, symbolId])
}

model SignVideo {
  id           String          @id @default(cuid())
  word         String
  videoUrl     String
  thumbnailUrl String?
  category     String
  source       SignVideoSource @default(BUILTIN)
  createdAt    DateTime        @default(now())

  uploadedById String?
  uploadedBy   Profile? @relation("UploadedSignVideos", fields: [uploadedById], references: [id], onDelete: SetNull)

  activities Activity[]
}

enum SignVideoSource {
  BUILTIN
  CUSTOM
}

// ─── Reward System ─────────────────────────────────────────────────────

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  cost        Int
  createdAt   DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  redemptions Redemption[]
}

model Redemption {
  id        String   @id @default(cuid())
  cost      Int
  createdAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
}

model EarnedPoint {
  id        String   @id @default(cuid())
  amount    Int
  reason    String?
  createdAt DateTime @default(now())

  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  criteria    String
  createdAt   DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  earnedBadges EarnedBadge[]
}

model EarnedBadge {
  id       String   @id @default(cuid())
  earnedAt DateTime @default(now())

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([profileId, badgeId])
}

// ─── Themes ────────────────────────────────────────────────────────────

model Theme {
  id              String  @id @default(cuid())
  name            String
  isBuiltIn       Boolean @default(false)
  primaryColor    String
  secondaryColor  String
  backgroundColor String
  textColor       String
  accentColor     String

  profiles Profile[]
}

// ─── Kanban ────────────────────────────────────────────────────────────

model KanbanBoard {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  columns KanbanColumn[]
}

model KanbanColumn {
  id        String @id @default(cuid())
  title     String
  sortOrder Int    @default(0)
  color     String @default("#6366f1")

  boardId String
  board   KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  activities Activity[]
}
